---
import { Image } from 'astro:assets';
import { instructors } from '../data/course';
import alexImg from '../assets/imgs/alex.jpg';
import mzImg from '../assets/imgs/mz.jpeg';

const photos: Record<string, ImageMetadata> = {
  'imgs/alex.jpg': alexImg,
  'imgs/mz.jpeg': mzImg,
};
---

<section id="team" class="section team">
  <div class="container-x">
    <div class="section-head" data-reveal>
      <p class="eyebrow">Who teaches it</p>
      <h2 class="font-display section-title">Instructors</h2>
    </div>

    <div class="team__grid">
      {instructors.map((p) => (
        <article class="prof" data-reveal>
          <div class="prof__photo">
            <Image
              src={photos[p.img]}
              alt={`Portrait of ${p.name}`}
              widths={[320, 640]}
              sizes="(min-width: 760px) 30vw, 90vw"
              format="webp"
              quality={78}
            />
          </div>
          <div class="prof__body">
            <h3 class="font-display prof__name">{p.name}</h3>
            <p class="prof__role">{p.role}</p>
            <a href={p.orgHref} target="_blank" rel="noopener noreferrer" class="prof__org link-underline">{p.org}</a>
            <a href={p.linkedin} target="_blank" rel="noopener noreferrer" class="prof__linkedin">
              LinkedIn <span aria-hidden="true">↗</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .team__grid {
    display: grid;
    gap: clamp(1.5rem, 4vw, 3rem);
    grid-template-columns: 1fr;
    max-width: 60rem;
  }
  .prof { display: flex; flex-direction: column; }
  .prof__photo {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 1.25rem;
    background: var(--color-mist);
    border: 1px solid var(--color-line);
  }
  .prof__photo :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(1) contrast(1.02);
    transition: filter 0.6s ease, transform 0.8s var(--ease-out-expo);
  }
  .prof:hover .prof__photo :global(img) { filter: grayscale(0); transform: scale(1.03); }
  .prof__body { padding-top: 1.3rem; }
  .prof__name { font-size: clamp(1.4rem, 2.4vw, 1.9rem); font-weight: 500; letter-spacing: -0.02em; margin: 0; }
  .prof__role { font-family: var(--font-mono); font-size: 0.75rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--color-accent); margin: 0.5rem 0 0.8rem; }
  .prof__org { display: inline-block; color: var(--color-slate); }
  .prof__linkedin { display: block; margin-top: 0.8rem; font-family: var(--font-mono); font-size: 0.82rem; color: var(--color-ink); }
  .prof__linkedin span { color: var(--color-accent); }

  @media (min-width: 640px) { .team__grid { grid-template-columns: repeat(2, 1fr); } }
</style>
